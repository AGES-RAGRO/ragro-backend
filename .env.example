# Database Configuration
POSTGRES_DB=gearheads
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring Boot - Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gearheads
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Spring Boot - JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ============================================================================
# Keycloak - OAuth2 JWT Resource Server
# ============================================================================

# Keycloak server URL (without trailing slash)
KEYCLOAK_SERVER_URL=http://localhost:8180

# JWT Issuer URI - used by Spring Security to validate tokens
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/ragro

# JWK Set URI - used by Spring Security to fetch public keys
KEYCLOAK_JWK_SET_URI=http://localhost:8180/realms/ragro/protocol/openid-connect/certs

# Keycloak Admin credentials (used for user registration via Admin REST API)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
