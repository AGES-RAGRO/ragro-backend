# Database Configuration
POSTGRES_DB=gearheads
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring Boot - Database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/gearheads
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Spring Boot - JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# AWS Cognito - JWT Resource Server
# Substitua <REGION> e <USER_POOL_ID> pelos valores do seu Cognito
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://cognito-idp.REGION.amazonaws.com/USER_POOL_ID
