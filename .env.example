# Database Configuration
POSTGRES_DB=gearheads
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring Boot - Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gearheads
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Spring Boot - JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ============================================================================
# AWS Cognito - OAuth2 Login + JWT Resource Server
# ============================================================================

# Issuer URI - Substitua <REGION> e <USER_POOL_ID> pelos dados do seu User Pool
# Exemplo: https://cognito-idp.us-east-1.amazonaws.com/us-east-1_abc123xyz
AWS_COGNITO_ISSUER_URI=https://cognito-idp.REGION.amazonaws.com/REGION_USER_POOL_ID

# OAuth2 Client Registration (App Client no Cognito)
# Substitua pelos valores da sua App Client no Cognito
AWS_COGNITO_CLIENT_ID=your-client-id-here
AWS_COGNITO_CLIENT_SECRET=your-client-secret-here

# OAuth2 Redirect URI - deve estar configurado em App Client > Callback URLs
# Para desenvolvimento local:
AWS_COGNITO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/cognito

# Cognito Domain - URL base para OAuth2 authorization
# Exemplo: https://mydomain.auth.us-east-1.amazoncognito.com
# Ou para Cognito-hosted domain: https://DOMAIN.auth.REGION.amazoncognito.com
AWS_COGNITO_DOMAIN=https://your-cognito-domain.auth.REGION.amazoncognito.com

# Logout redirect URI - para onde redirecionar após logout do Cognito
AWS_COGNITO_LOGOUT_URI=http://localhost:8080/
